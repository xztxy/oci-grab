# ===== 必填:从 OCI 控制台获取的 OCID =====
COMPARTMENT_ID=ocid1.tenancy.oc1..xxxxxxxx
SUBNET_ID=ocid1.subnet.oc1.ap-tokyo-1.xxxxxxxx
IMAGE_ID=ocid1.image.oc1.ap-tokyo-1.xxxxxxxx

# ===== 实例配置 =====
DISPLAY_NAME=free-arm
SHAPE=VM.Standard.A1.Flex
OCPUS=4
MEMORY_GB=24
BOOT_VOLUME_GB=100

# 容器内 SSH 公钥路径(对应 ./keys/id_rsa.pub 挂载)
SSH_KEY_FILE=/keys/id_rsa.pub

# 重试间隔(秒),建议 60-120,过短会触发 429 限流
SLEEP_SECONDS=60

# 可选:指定可用域(逗号分隔),留空则自动获取全部
# AVAILABILITY_DOMAINS=xxxx:AP-TOKYO-1-AD-1,xxxx:AP-TOKYO-1-AD-2

# ===== 可选:通知渠道(抢到/抢满/出错时推送)=====
# PushPlus 微信推送:登录 https://www.pushplus.plus 获取 token(国内直连,无需代理)
PUSHPLUS_TOKEN=
# PushPlus 群组编码(可选,一对多推送;留空为一对一发给自己)
PUSHPLUS_TOPIC=
# Telegram 机器人:@BotFather 创建获取 token;chat_id 可用 @userinfobot 获取
TG_BOT_TOKEN=
TG_CHAT_ID=
# Telegram 代理(国内连 api.telegram.org 一般必填),如 http://192.168.1.1:7890;仅作用于 Telegram
NOTIFY_PROXY=
